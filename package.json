{
  "name": "abitia",
  "version": "0.1.0",
  "private": true,
  "description": "Abitia — Sistema de Gestión Integral Multi-Condominio (Fase Magra)",
  "workspaces": [
    "packages/core",
    "packages/data",
    "packages/services",
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev:api",
    "dev:api": "npm run dev -w packages/api",
    "dev:web": "npm run dev -w packages/web",
    "logs": "npm run logs -w packages/api",
    "deploy": "node scripts/deploy.js",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "typecheck": "tsc -b",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "basic-ftp": "^6.0.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.9.0",
    "reflect-metadata": "^0.2.1",
    "tsyringe": "^4.8.0"
  }
}
